# ── Clés API ──────────────────────────────────────────────────────────────────
MISTRAL_API_KEY=votre_clé_api_mistral_ici
TAVILY_API_KEY=votre_clé_api_tavily_ici

# ── Configuration LLM ─────────────────────────────────────────────────────────
# local  : génération via Ollama + Phi-3 Mini (données sensibles)
# cloud  : génération via API Mistral (données publiques)
LLM_MODE=local

# ── Chemins données ───────────────────────────────────────────────────────────
CHROMA_PATH=./data/chroma

# ── Veille réglementaire ──────────────────────────────────────────────────────
# Heure de déclenchement du cron Docker (0-23)
VEILLE_HEURE=6

# ── API Légifrance (non opérationnel — erreur 500 PISTE non résolue) ──────────
# LEGIFRANCE_API_KEY=votre_client_id_piste
# LEGIFRANCE_API_SECRET=votre_client_secret_piste


# Désactive l'avertissement symlinks HuggingFace sur Windows
HF_HUB_DISABLE_SYMLINKS_WARNING=1